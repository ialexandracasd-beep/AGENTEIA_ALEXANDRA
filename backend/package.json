{
  "name": "agenteia-alexandra-backend",
  "version": "1.0.0",
  "description": "Backend para el sistema AgenteIA Alexandra - Revisión metodológica con IA",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "lint": "eslint src --ext .ts",
    "type-check": "tsc --noEmit",
    "import:students": "ts-node src/scripts/import-students.ts"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "helmet": "^7.1.0",
    "@supabase/supabase-js": "^2.38.4",
    "googleapis": "^128.0.0",
    "@google/generative-ai": "^0.2.1",
    "zod": "^3.22.4",
    "winston": "^3.11.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/node": "^20.10.0",
    "typescript": "^5.3.2",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0"
  }
}
