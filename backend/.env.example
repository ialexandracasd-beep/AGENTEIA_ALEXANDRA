# Servidor
PORT=3001
NODE_ENV=development

# CORS / URLs
CORS_ORIGIN=http://localhost:3000
FRONTEND_URL=http://localhost:3000

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Google — Service Account
GOOGLE_PROJECT_ID=your-google-project-id
GOOGLE_SERVICE_ACCOUNT_EMAIL=alexandra-agent@your-project.iam.gserviceaccount.com
# Copiar el private_key del JSON descargado — reemplazar saltos de línea reales por \n
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...(tu clave)...\n-----END PRIVATE KEY-----\n"

# Google Drive
GOOGLE_DRIVE_ROOT_FOLDER_ID=your-root-folder-id

# Google Sheets — Plantilla y acceso de la profesora
GOOGLE_TEMPLATE_SHEET_ID=your-template-sheet-id
GOOGLE_TEACHER_EMAIL=profesora@universidad.edu.co

# Gemini AI
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash
